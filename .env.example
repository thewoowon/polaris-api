# --- App ---
PROJECT_NAME=Polaris API
DEBUG=true

# --- Database ---
# Async SQLAlchemy URL; swap host `db` for local docker-compose or `localhost` for bare-metal.
DATABASE_URL=postgresql+asyncpg://polaris:polaris@localhost:5432/polaris

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# JSON array or comma-separated list of allowed frontend origins.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- Ingestion worker ---
# Auto-starts the periodic loop on lifespan. Only enable in ONE uvicorn
# worker to avoid duplicate ingestion.
INGESTION_ENABLED=false
INGESTION_INTERVAL_SEC=60
# Comma-separated: any of synthetic, google_play, app_store
INGESTION_SOURCES=synthetic
# Runs classifier + policy automatically right after each ingested review.
# Draft generation stays manual regardless.
INGESTION_AUTO_PIPELINE=false
INGESTION_AUTO_CLASSIFIER=stub   # stub | openai  (openai incurs per-review cost)

# Google Play — public page scraping via google-play-scraper; no API key.
# Leave APP_ID empty to skip this source even if listed above.
INGESTION_GOOGLE_PLAY_APP_ID=
INGESTION_GOOGLE_PLAY_LANG=ko
INGESTION_GOOGLE_PLAY_COUNTRY=kr
INGESTION_GOOGLE_PLAY_COUNT=20

# App Store — iTunes RSS feed; numeric id only (no API key).
INGESTION_APP_STORE_APP_ID=
INGESTION_APP_STORE_COUNTRY=kr
